<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>

        <!-- Cache: use array driver so framework-level caching does not touch Redis -->
        <env name="CACHE_STORE" value="array"/>

        <!--
            Database: MySQL (same Docker service as production).
            Using a dedicated test database avoids polluting production data.

            Pre-requisite — create the test database once inside the container:
                docker exec laravel_mysql mysql -uroot \
                    -e "CREATE DATABASE IF NOT EXISTS multi_tenant_api_test;
                        GRANT ALL PRIVILEGES ON multi_tenant_api_test.* TO 'laravel'@'%';"

            Credentials below match the docker-compose defaults.
            Override via .env.testing (gitignored) for different environments.
        -->
        <env name="DB_CONNECTION" value="mysql"/>
        <env name="DB_HOST" value="laravel_mysql"/>
        <env name="DB_PORT" value="3306"/>
        <env name="DB_DATABASE" value="multi_tenant_api_test"/>
        <env name="DB_USERNAME" value="laravel"/>
        <env name="DB_PASSWORD" value="secret"/>
        <env name="DB_URL" value=""/>

        <!--
            Redis: point to the Docker service name so tests running inside
            laravel_app can reach Redis at laravel_redis:6379.
        -->
        <env name="REDIS_HOST" value="laravel_redis"/>
        <env name="REDIS_PORT" value="6379"/>
        <env name="REDIS_CLIENT" value="phpredis"/>
        <!--
            Use Redis database 1 for tests to isolate from production data
            which lives on database 0.
        -->
        <env name="REDIS_DB" value="1"/>
        <env name="REDIS_CACHE_DB" value="2"/>

        <!--
            Queue: 'sync' keeps Queue::fake() working without a live worker.
            The middleware dispatches jobs but Queue::fake() intercepts them.
            Set to 'redis' only if you want to test the actual queue pipeline.
        -->
        <env name="QUEUE_CONNECTION" value="sync"/>

        <!-- API Gateway module: use same Redis DB as above -->
        <env name="API_GATEWAY_REDIS_CONNECTION" value="default"/>
        <env name="API_GATEWAY_QUEUE_CONNECTION" value="sync"/>

        <env name="MAIL_MAILER" value="array"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
    </php>
</phpunit>

